rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // 프로필 최상위 문서 — 읽기만 허용, 쓰기는 Admin SDK 전용
      // (프로필 데이터는 Supabase로 이전 완료, Firestore 직접 쓰기 불필요)
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;

      // garden/plant — 읽기만 허용
      // 쓰기: POST /api/garden/plant-exp (Admin SDK FieldValue.increment)
      //       Chrome 확장도 API Route 경유로만 적립
      match /garden/plant {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // garden/animal — 읽기만 허용
      // 쓰기: POST /api/garden/animal (Admin SDK)
      //       동물 선택·변경·스트릭 모두 서버 경유
      match /garden/animal {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // notifications — 읽기/쓰기 허용 (10단계 알림 시스템용)
      match /notifications/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // analyses — 읽기만 허용, 쓰기는 Cloud Function(Admin SDK)만
      match /analyses/{analysisId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // 그 외 모든 접근 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
